<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
            http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Book ID Generator -->
    <bean name="egovBookIdGnrService"
          class="org.egovframe.rte.fdl.idgnr.impl.EgovTableIdGnrServiceImpl"
          destroy-method="destroy">
        <property name="dataSource" ref="dataSource"/>
        <property name="strategy" ref="bookIdStrategy"/>
        <property name="blockSize" value="10"/>
        <property name="table" value="IDS"/>
        <property name="tableName" value="BOOK_ID"/>
    </bean>

    <bean name="bookIdStrategy"
          class="org.egovframe.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
        <property name="prefix" value="BOOK_"/>
        <property name="cipers" value="6"/>
        <property name="fillChar" value="0"/>
    </bean>

</beans>
